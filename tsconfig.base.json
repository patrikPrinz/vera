{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "target": "es2022",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    "sourceMap": true,
    "composite": true,
  }
}
